{
  "name": "vt100.js",
  "version": "0.1.1",
  "description": "Pure TypeScript VT100 terminal emulator. Zero dependencies, headless, fast.",
  "keywords": [
    "ansi",
    "headless",
    "terminal-emulator",
    "tui",
    "typescript",
    "vt100",
    "zero-dependency"
  ],
  "homepage": "https://github.com/beorn/vt100",
  "bugs": "https://github.com/beorn/vt100/issues",
  "license": "MIT",
  "author": "Beorn",
  "repository": "github:beorn/vt100",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "bun run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^4.0.0"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18"
  }
}
